{
  "name": "weblock-token",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf cache artifacts coverage typechain-types",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat test",
    "deploy:subnet": "hardhat run scripts/deploy.js --network avalancheSubnet",
    "series:create": "hardhat run scripts/create-series.js --network avalancheSubnet",
    "rbt:action": "hardhat run scripts/rbt-action.js --network avalancheSubnet",
    "foundation:action": "hardhat run scripts/foundation-action.js --network avalancheSubnet",
    "format": "prettier --plugin prettier-plugin-solidity --write \"contracts/**/*.sol\" \"test/**/*.js\" \"scripts/**/*.js\" \"docs/**/*.md\" \"README.md\" \"hardhat.config.js\"",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "check": "pnpm compile && pnpm test"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-mocha": "^3.0.1",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "chai": "^6.2.0",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.12",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.0.3"
  },
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228"
}
